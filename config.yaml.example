# Claude Code engine settings
engine:
  # model: claude-sonnet-4-6   # optional, uses default if omitted
  max_turns: 0                  # 0 = unlimited

  # Permission mode for non-interactive use. Options:
  #   bypassPermissions - skip all permission checks (full auto, use with caution)
  #   acceptEdits       - auto-accept file edits, still ask for bash
  #   default           - ask for everything (won't work in -p mode)
  permission_mode: bypassPermissions

  # Optional: whitelist specific tools instead of allowing all.
  # Examples: ["Bash", "Edit", "Read", "Write", "Glob", "Grep"]
  # Leave empty/null to allow all tools.
  # allowed_tools: ["Read", "Grep", "Glob", "Bash", "Edit", "Write"]
  allowed_tools: null

  # Optional: disable specific built-in tools (merged with extension-registered ones).
  # Extensions auto-register replacements (e.g. ask_user disables AskUserQuestion).
  # Add here for additional user-level overrides.
  # disallowed_tools: ["TodoWrite", "TodoRead"]
  disallowed_tools: null

# Persistent state directory for sessions (supports ~ expansion)
state_dir: ~/.claude-ext

# Session management
sessions:
  max_sessions_per_user: 5       # Max concurrent sessions per user (= slot count)
                                 # Tip: increase to 8-10 when using subagent extension

# Extensions to enable (must match directory names under extensions/)
# Order matters: dependencies must come before dependents.
# IMPORTANT: vault must come before memory (personality encryption depends on vault).
enabled:
  # - vault                        # Encrypted credential vault (required by memory personality, wallet, email)
  # - memory                       # Three-layer identity + persistent knowledge store (load after vault)
  - telegram
  # - ask_user                     # Uncomment to let Claude ask the user questions mid-session
  # - heartbeat                     # Autonomous periodic task agent
  # - cron                         # Uncomment to enable scheduled tasks
  # - subagent                     # Multi-agent orchestration (PM spawns workers)
  # - session_ask                  # Cross-session RPC (session-to-session Q&A)

# Per-extension configuration
extensions:
  telegram:
    token: "YOUR_BOT_TOKEN"
    # Telegram user IDs or usernames allowed to use the bot.
    # Empty list = no restriction (NOT recommended for production).
    allowed_users: []
    # Default working directory for Claude Code. null = current directory.
    # Can be overridden per-session with /new <name> <dir>
    working_dir: null
    # streaming: partial         # Real-time draft streaming (requires bot forum topic mode)

  ask_user:
    timeout: 300                   # Seconds to wait for user response before timing out

  vault:
    # Passphrase: auto-generated and stored in {state_dir}/vault/.passphrase (0600).
    # Override with CLAUDE_EXT_VAULT_PASSPHRASE env var if you need a specific one.
    # The env var is automatically unset in Claude sessions to prevent leakage.
    {}

  memory:
    # Three-layer identity system + knowledge store. Files in {state_dir}/memory/.
    # Personality encryption requires vault to be enabled and listed before memory.
    # On first run, auto-migrates from v1 format (creates constitution.md, TOPICS_INDEX.md,
    # archives daily/ logs, creates users/ and events/ directories).
    {}

  heartbeat:
    interval: 1800                   # Base interval in seconds (default 30 minutes)
    # active_hours: "08:00-22:00"    # Optional UTC active window
    max_daily_runs: 48               # Max Tier 2 decisions per day
    usage_throttle: 80               # Usage >= this: only immediate triggers allowed
    usage_pause: 95                  # Usage >= this: all heartbeats paused
    user_id: "123456789"             # Required: owner user ID
    notify_context:                  # Delivery routing
      chat_id: 123456789             # Telegram chat ID for Tier 3 results
    working_dir: null                # Default working directory (null = cwd)
    # Optional: read-only commands to run before Tier 2 LLM decision.
    # Output is injected as context so the LLM has real-world data.
    # Max 3 commands, each with configurable timeout (default 10s, max 30s).
    # recon_commands:
    #   - cmd: "git log --oneline -5"
    #     label: "Recent commits"
    #   - cmd: "ruff check --statistics"
    #     label: "Lint status"
    #     timeout: 15

  cron:
    # Static jobs (optional). Claude can also create jobs dynamically via MCP tools.
    jobs: []
    # Example static job:
    # jobs:
    #   - name: daily-review
    #     cron_expr: "0 9 * * *"
    #     prompt: "Review yesterday's git commits and summarize changes"
    #     working_dir: /home/user/project
    #     user_id: "123456789"           # Must match a Telegram user_id for notifications
    #     session_strategy: new           # "new" or "reuse"
    #     notify_context:                 # Routing info for result delivery
    #       chat_id: 123456789            # Telegram chat ID to send results to

  subagent:
    max_subagents_per_session: 5     # Max active sub-agents per PM session
    default_paradigm: coder          # Default worker paradigm
    cleanup_delay: 120.0             # Seconds before auto-destroying completed worker sessions
    # Custom paradigms (merged with built-in: coder, reviewer, researcher):
    # paradigms:
    #   tester:
    #     system_prompt: "You are a testing specialist. Write comprehensive tests."
    #     disallowed_tools: []
    #     auto_cleanup: true

  session_ask:
    timeout: 300                   # Seconds to wait for target session's reply
    max_question_length: 2000      # Max characters for question text
