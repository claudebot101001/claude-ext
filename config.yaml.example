# Claude Code engine settings
engine:
  # model: claude-sonnet-4-6   # optional, uses default if omitted
  max_turns: 0                  # 0 = unlimited

  # Permission mode for non-interactive use. Options:
  #   bypassPermissions - skip all permission checks (full auto, use with caution)
  #   acceptEdits       - auto-accept file edits, still ask for bash
  #   default           - ask for everything (won't work in -p mode)
  permission_mode: bypassPermissions

  # Optional: whitelist specific tools instead of allowing all.
  # Examples: ["Bash", "Edit", "Read", "Write", "Glob", "Grep"]
  # Leave empty/null to allow all tools.
  # allowed_tools: ["Read", "Grep", "Glob", "Bash", "Edit", "Write"]
  allowed_tools: null

  # Gateway mode: consolidate each extension's MCP tools into a single gateway tool.
  # Reduces ~6,000 tokens of MCP tool schemas to ~1,000 per API call.
  # Claude calls action='help' to discover commands, then action='<cmd>' with params.
  # Servers with only 1 tool (e.g. ask_user) are exempt automatically.
  # gateway_mode: true
  gateway_mode: false

  # Optional: disable specific built-in Claude Code tools.
  # Merged with extension-registered ones (e.g. ask_user auto-disables AskUserQuestion).
  #
  # Built-in tools reference:
  #   ESSENTIAL (do not disable):
  #     Read, Edit, Write, Bash, Glob, Grep  — core file/shell operations
  #
  #   SAFE TO DISABLE (saves ~500-1000 tokens each):
  #     TodoWrite, TodoRead     — task tracking (MCP extensions can replace)
  #     WebFetch                — URL fetching (if not needed)
  #     WebSearch               — web search (if not needed)
  #     NotebookEdit            — Jupyter notebook editing
  #     AskUserQuestion         — auto-disabled when ask_user extension is enabled
  #
  #   CAUTION:
  #     Agent                   — sub-agent spawning (disable if using subagent extension only)
  #     EnterPlanMode, ExitPlanMode — planning workflow
  #
  # Example profiles:
  #   Conservative: ["TodoWrite", "TodoRead"]
  #   Minimal:      ["TodoWrite", "TodoRead", "WebFetch", "WebSearch", "NotebookEdit"]
  #
  # disallowed_tools: ["TodoWrite", "TodoRead"]
  disallowed_tools: null

# Persistent state directory for sessions (supports ~ expansion)
state_dir: ~/.claude-ext

# Session management
sessions:
  max_sessions_per_user: 5       # Max concurrent sessions per user (= slot count)
                                 # Tip: increase to 8-10 when using subagent extension
  session_timeout: 7200           # Max seconds a single prompt execution can run (default 2h)

# Extensions to enable (must match directory names under extensions/)
# Order matters: dependencies must come before dependents.
# IMPORTANT: vault must come before memory (personality encryption depends on vault).
enabled:
  # - vault                        # Encrypted credential vault (required by memory personality, wallet, email)
  # - memory                       # Three-layer identity + persistent knowledge store (load after vault)
  - telegram
  # - ask_user                     # Uncomment to let Claude ask the user questions mid-session
  # - heartbeat                     # Autonomous periodic task agent
  # - cron                         # Uncomment to enable scheduled tasks
  # - subagent                     # Multi-agent orchestration (PM spawns workers)
  # - session_ask                  # Cross-session RPC (session-to-session Q&A)
  # - crypto                       # On-chain wallet management (requires vault)
  # - context                      # Context window monitoring and compaction control
  # - browser                      # Web browser automation (agent-browser CLI)

# Per-extension configuration
extensions:
  telegram:
    token: "YOUR_BOT_TOKEN"
    # Telegram user IDs or usernames allowed to use the bot.
    # Empty list = no restriction (NOT recommended for production).
    allowed_users: []
    # Default working directory for Claude Code. null = current directory.
    # Can be overridden per-session with /new <name> <dir>
    working_dir: null

  ask_user:
    timeout: 300                   # Seconds to wait for user response before timing out

  vault:
    # Passphrase: auto-generated and stored in {state_dir}/vault/.passphrase (0600).
    # Override with CLAUDE_EXT_VAULT_PASSPHRASE env var if you need a specific one.
    # The env var is automatically unset in Claude sessions to prevent leakage.
    {}

  memory:
    # Three-layer identity system + knowledge store. Files in {state_dir}/memory/.
    # Personality encryption requires vault to be enabled and listed before memory.
    # On first run, auto-migrates from v1 format (creates constitution.md, TOPICS_INDEX.md,
    # archives daily/ logs, creates users/ and events/ directories).
    {}

  heartbeat:
    interval: 1800                   # Base interval in seconds (default 30 minutes)
    # active_hours: "08:00-22:00"    # Optional UTC active window
    max_daily_runs: 48               # Max Tier 2 decisions per day
    usage_throttle: 80               # Usage >= this: only immediate triggers allowed
    usage_pause: 95                  # Usage >= this: all heartbeats paused
    user_id: "123456789"             # Required: owner user ID
    notify_context:                  # Delivery routing
      chat_id: 123456789             # Telegram chat ID for Tier 3 results
    working_dir: null                # Default working directory (null = cwd)
    # Optional: read-only commands to run before Tier 2 LLM decision.
    # Output is injected as context so the LLM has real-world data.
    # Max 3 commands, each with configurable timeout (default 10s, max 30s).
    # recon_commands:
    #   - cmd: "git log --oneline -5"
    #     label: "Recent commits"
    #   - cmd: "ruff check --statistics"
    #     label: "Lint status"
    #     timeout: 15

  cron:
    # Static jobs (optional). Claude can also create jobs dynamically via MCP tools.
    jobs: []
    # Example static job:
    # jobs:
    #   - name: daily-review
    #     cron_expr: "0 9 * * *"
    #     prompt: "Review yesterday's git commits and summarize changes"
    #     working_dir: /home/user/project
    #     user_id: "123456789"           # Must match a Telegram user_id for notifications
    #     session_strategy: new           # "new" or "reuse"
    #     notify_context:                 # Routing info for result delivery
    #       chat_id: 123456789            # Telegram chat ID to send results to

  subagent:
    max_subagents_per_session: 5     # Max active sub-agents per PM session
    default_paradigm: coder          # Default worker paradigm
    cleanup_delay: 120.0             # Seconds before auto-destroying completed worker sessions
    # Custom paradigms (merged with built-in: coder, reviewer, researcher):
    # paradigms:
    #   tester:
    #     system_prompt: "You are a testing specialist. Write comprehensive tests."
    #     disallowed_tools: []
    #     auto_cleanup: true

  session_ask:
    timeout: 300                   # Seconds to wait for target session's reply
    max_question_length: 2000      # Max characters for question text

  crypto:
    # On-chain wallet management, contract interaction, x402 payments.
    # Requires vault extension enabled and loaded before crypto.
    # Prerequisites: pip install "eth-account>=0.13,<0.15" "eth-abi>=5.0,<6.0" "httpx>=0.27,<1.0"
    chains:
      base:
        rpc_url: "https://mainnet.base.org"
        chain_id: 8453
        explorer_url: "https://basescan.org"
        native_symbol: "ETH"
        usdc_address: "0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913"
      ethereum:
        rpc_url: "https://eth.llamarpc.com"
        chain_id: 1
        explorer_url: "https://etherscan.io"
        native_symbol: "ETH"
        usdc_address: "0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48"
      # sepolia:
      #   rpc_url: "https://rpc.sepolia.org"
      #   chain_id: 11155111
      #   explorer_url: "https://sepolia.etherscan.io"
      #   native_symbol: "ETH"
      #   testnet: true
    x402:
      default_network: "base"
      facilitator_url: null            # null = Coinbase CDP default
    tx:
      gas_multiplier: 1.2             # Safety margin on gas estimates
      receipt_timeout: 120             # Seconds to wait for tx receipt
    default_chain: "ethereum"

  context:
    auto_compact:
      enabled: false               # Off by default — costs API tokens when triggered
      threshold_pct: 85            # Trigger compaction when context fill exceeds this %
      cooldown_prompts: 3          # Skip N prompts after compaction before re-checking

  browser:
    # Web automation + scraping + stealth browsing extension
    # Tier 1 - agent-browser: interactive browser (CLI via Bash)
    #   Prerequisites: npm install -g agent-browser && agent-browser install
    #   On Linux: agent-browser install --with-deps (for system Chromium dependencies)
    # Tier 2 - Scrapling: anti-bot web scraping (MCP gateway)
    #   Prerequisites: pip install "scrapling[all]"
    # Tier 3 - Patchright stealth: anti-detect interactive browser (MCP gateway)
    #   Prerequisites: pip install patchright && python -m patchright install chromium
    #   For CAPTCHA solving: download NopeCHA extension to extensions/browser/vendor/
    #   For headless+extensions on Linux: apt-get install xvfb
    # binary: agent-browser         # Override path to agent-browser binary
    stealth:
      enabled: true
      captcha_solver: none           # "nopecha" or "none"
      idle_timeout: 300              # Seconds before auto-closing idle browser
      chromium_args: []              # Additional Chromium launch flags
      # nopecha_api_key: ""          # Optional, for NopeCHA paid tier
      profiles_dir: null             # Default: ~/.claude-ext/browser_profiles
      # auth_skip_domains:           # Domains where evasion injection is skipped
      #   - accounts.google.com
      #   - accounts.youtube.com
      #   - github.com
      #   - api.github.com
      #   - appleid.apple.com
      #   - login.microsoftonline.com
      #   - login.live.com
      #   - www.facebook.com
      #   - m.facebook.com
      #   - login.yahoo.com
      #   - id.atlassian.com
      proxy:
        server: null                 # e.g. socks5://proxy:1080, http://proxy:8080
        # vault_key: null            # For authenticated proxies (future: bridge RPC)
